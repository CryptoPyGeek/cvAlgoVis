{
  "name": "cvalgovis-workspace",
  "private": true,
  "scripts": {
    "clean:desktop": "powershell -ExecutionPolicy Bypass -File scripts/clean-desktop.ps1",
    "build:web": "npm --prefix frontend run build",
    "build:backend": "py -3 -m pip install -r backend/requirements.txt && py -3 -m PyInstaller backend/pyinstaller.spec --distpath backend/dist --workpath backend/build",
    "smoke:desktop": "powershell -ExecutionPolicy Bypass -File scripts/smoke-test-desktop.ps1",
    "build:desktop:win": "powershell -ExecutionPolicy Bypass -File scripts/build-desktop-win.ps1",
    "build:desktop": "npm run build:desktop:win"
  }
}
