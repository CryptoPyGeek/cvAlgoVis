{
  "name": "cvalgovis-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build": "npm run build:win:portable",
    "build:win:portable": "electron-builder --config electron-builder.yml --win portable --config.electronDist=node_modules/electron/dist",
    "build:win:dir": "electron-builder --config electron-builder.yml --dir --config.electronDist=node_modules/electron/dist"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  }
}
